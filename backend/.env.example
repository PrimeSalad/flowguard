# Copy to .env and adjust as needed.
PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
# Allowed frontend origin(s), comma-separated, no trailing slash.
# In production set this to your Vercel URL(s), e.g.
# CORS_ORIGIN=https://flowguard.vercel.app,https://your-preview.vercel.app
CORS_ORIGIN=http://localhost:5173

# --- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=your-sb_secret_key
# Optional: personal access token (sbp_...) from
# https://supabase.com/dashboard/account/tokens
# When set, the server auto-applies supabase/schema.sql on every boot.
SUPABASE_ACCESS_TOKEN=your-sbp-access-token
