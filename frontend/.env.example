# Copy to .env.local for local dev (optional — dev uses the Vite proxy).
#
# In production (Vercel), set VITE_API_URL to your deployed backend origin,
# with NO trailing slash and NO /api suffix. Example:
#   VITE_API_URL=https://flowguard-api.onrender.com
#
# Leave empty to use the same-origin `/api` path (dev proxy / rewrites).
VITE_API_URL=
